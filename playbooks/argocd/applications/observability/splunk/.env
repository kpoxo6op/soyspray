SPLUNK_GENERAL_TERMS=--accept-sgt-current-at-splunk-com
SPLUNK_START_ARGS=--accept-license
SPLUNK_ADMIN_USERNAME=admin
SPLUNK_ADMIN_PASSWORD=AdminPassword123!
SPLUNK_SERVICE_ACCOUNT_USERNAME=svc_dashboards
SPLUNK_SERVICE_ACCOUNT_PASSWORD=ServiceDashboards123!
SPLUNK_SERVICE_ACCOUNT_ROLES=power
SPLUNK_APP_NAME=soyspray_dashboards
SPLUNK_APP_LABEL=Soyspray Dashboards
SPLUNK_APP_DESCRIPTION=Dashboards managed from the soyspray repo over Splunk REST.
SPLUNK_NAMESPACE=splunk
SPLUNK_POD_LABEL_SELECTOR=app=splunk
SPLUNK_MGMT_LOCAL_PORT=18089
SPLUNK_MGMT_REMOTE_PORT=8089
SPLUNK_MGMT_SCHEME=https
SPLUNK_MGMT_HOST=127.0.0.1
SPLUNK_VERIFY_TLS=false
SPLUNK_WEB_URL=https://splunk.soyspray.vip
SPLUNK_WEB_HOST=splunk.soyspray.vip
