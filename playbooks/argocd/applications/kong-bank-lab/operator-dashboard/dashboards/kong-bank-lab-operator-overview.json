  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "description": "Current traffic, failures, latency, readiness, and policy rejections.",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / second",
      "description": "Requests per second through Kong. Roughly, this is how busy the gateway is right now.",
      "datasource": {
        "type": "prometheus",
        "uid": "$prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "reqps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(kong_http_requests_total{namespace=\"$namespace\",route=~\"$route\",code=~\"$status_code\"}[5m]))",
          "hide": false,
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Requests 15m",
      "description": "Total requests Kong handled in the last 15 minutes. This smooths out short spikes better than the 5 minute count.",
      "datasource": {
        "type": "prometheus",
        "uid": "$prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$prometheus"
          },
          "editorMode": "code",
          "expr": "sum(increase(kong_http_requests_total{namespace=\"$namespace\",route=~\"$route\",code=~\"$status_code\"}[15m]))",
          "hide": false,
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Server errors",
      "description": "Percent of requests that ended as 5xx server errors. This does not count 4xx client errors or 429 rate-limit rejections.",
      "datasource": {
        "type": "prometheus",
        "uid": "$prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$prometheus"
          },
          "editorMode": "code",
          "expr": "100 * sum(rate(kong_http_requests_total{namespace=\"$namespace\",route=~\"$route\",code=~\"5..\"}[5m])) / clamp_min(sum(rate(kong_http_requests_total{namespace=\"$namespace\",route=~\"$route\"}[5m])), 0.001)",
          "hide": false,
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p95 latency",
      "description": "p95 means 95 percent of requests were this fast or faster. The slowest 5 percent took longer than this number.",
      "datasource": {
        "type": "prometheus",
        "uid": "$prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(kong_request_latency_ms_bucket{namespace=\"$namespace\",route=~\"$route\"}[5m])))",
          "hide": false,
          "instant": true,
          "legendFormat": "",
          "range": false,
          "refId": "A",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Gateway pods",
